{
  "name": "tenet-aiaudit",
  "license": "Apache-2.0",
  "version": "0.1.0",
  "description": "EU AI Act audit log microservice — tamper-evident AI call logging, risk classification, auditor-ready evidence packs",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate -m migrations",
    "migrate:up": "node-pg-migrate -m migrations up",
    "migrate:down": "node-pg-migrate -m migrations down",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration --no-file-parallelism",
    "bootstrap": "tsx scripts/create-admin-key.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "openapi:snapshot": "tsx scripts/openapi-snapshot.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@sinclair/typebox": "^0.34.33",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "node-pg-migrate": "^7.9.1",
    "pdfkit": "^0.17.1",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.15.3",
    "@types/pdfkit": "^0.13.9",
    "@types/unzipper": "^0.10.11",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "unzipper": "^0.12.3",
    "vitest": "^3.1.3"
  }
}
